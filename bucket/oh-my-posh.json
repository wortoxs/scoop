{
    "version": "12.2.0",
    "description": "A prompt theme engine for any shell",
    "homepage": "https://ohmyposh.dev",
    "license": {
        "identifier": "MIT",
        "url": "https://github.com/JanDeDobbeleer/oh-my-posh/blob/main/COPYING"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/JanDeDobbeleer/oh-my-posh/releases/download/v12.2.0/posh-windows-amd64.7z",
            "hash": "cc18c57310c3028a029c1ad5b57824150003f282627e4eb70c9a9328695fbf14"
        }
    },
    "env_add_path": "bin",
    "env_set": {
        "POSH_THEMES_PATH": "$dir\\themes"
    },
    "checkver": {
        "github": "https://github.com/JanDeDobbeleer/oh-my-posh"
    },
    "post_install": [
        "Write-Host 'Thanks for installing Oh My Posh.'",
        "Write-Host 'Have a look at https://ohmyposh.dev for detailed instructions for your shell.'"
    ],
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/JanDeDobbeleer/oh-my-posh/releases/download/v$version/posh-windows-amd64.7z",
                "hash": {
                    "url": "$url.sha256"
                }
            }
        }
    }
}
